# .env — Environment Variables for Sell Option Scanner
# =====================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitgnore).

# ── Telegram Bot ─────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Get from @userinfobot on Telegram (your personal chat ID)
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ── Anthropic Claude AI ───────────────────────────────
# Required for the /askclaude command in Telegram
# Get your key from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── OpenRouter (Llama & other LLMs) ──────────────────
# Required for the /askllama command in Telegram
# Get your key from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── IBKR Settings (optional overrides) ───────────────
# Default: auto-detect port (7497, 4002, 7496, 4001)
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=10

# ── Supabase data ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co

# Browser/public anon key. Frontend uses NEXT_PUBLIC_SUPABASE_ANON_KEY.
SUPABASE_KEY=your-supabase-anon-key-here

# Server-only key for FastAPI/worker after production RLS is tightened.
# Never expose this to frontend code or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Supabase auth.users.id UUID that owns legacy Telegram/scanner workflow rows.
# Required so Telegram candidate/portfolio commands do not read or write unowned rows.
OPTIONBOT_OWNER_USER_ID=your-supabase-user-uuid-here

# ── Stripe Billing ───────────────────────────────────
# Keep beta mode true until Checkout, webhooks, and the subscription table are
# verified in production. Set false only when ready to enforce paid tiers.
OPTIONBOT_BETA_ALL_MAX=true

# Server-only Stripe keys and webhook signing secret.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_API_VERSION=2026-02-25.clover

# Stripe Price IDs for recurring subscription prices.
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly
STRIPE_PRICE_PRO_ANNUAL=price_your_pro_annual
STRIPE_PRICE_MAX_MONTHLY=price_your_max_monthly
STRIPE_PRICE_MAX_ANNUAL=price_your_max_annual

# Comma-separated production frontend origins are allowed elsewhere; billing
# uses the first URL for Checkout success/cancel and portal return URLs.
FRONTEND_URL=http://localhost:3000

# Frontend-only backend API URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
